generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id
  name            String
  email           String
  emailVerified   Boolean
  image           String?
  createdAt       DateTime
  updatedAt       DateTime
  sessions        Session[]
  accounts        Account[]
  student         Student?
  faculty         Faculty?
  hod             Hod?
  admin           Admin?
  Freeze          Freeze[]
  username        String?
  displayUsername String?
  frozenAsFaculty Freeze[]  @relation("FrozenByFaculty")
  frozenAsHod     Freeze[]  @relation("FrozenByHod")
  frozenAsAdmin   Freeze[]  @relation("FrozenByAdmin")
  coe             Coe?

  banned     Boolean?
  banReason  String?
  banExpires DateTime?
  role       String?
  Semester   Semester[]
  Department Department[]

  @@unique([email])
  @@unique([username])
  @@map("user")
}

model AcademicTerm {
  id        String       @id @default(uuid())
  type      SemesterType
  year      String
  isCurrent Boolean      @default(false)

  Semester  Semester[]

  @@unique([type, year])
}

model Semester {
  id             String       @id @default(uuid())
  academicTermId String
  academicTerm   AcademicTerm @relation(fields: [academicTermId], references: [id], onDelete: Cascade)
  programType    ProgramType
  semesterNumber Int
  startDate      DateTime
  endDate        DateTime
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  createdBy      User         @relation(fields: [userId], references: [id])
  userId         String
  Section        Section[]
  Course         Course[]
  Admission      Admission[]

  @@unique([academicTermId, programType, semesterNumber])
}

enum SemesterType {
  even
  odd
}

enum ProgramType {
  UG
  PG
}

enum CourseMode {
  INTEGRATED
  NON_INTEGRATED
  FINAL_SUMMARY
  NCMC
}

enum CourseType {
  PC
  PE
  OE
  NCMC
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  impersonatedBy String?

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

enum CondonationStatus {
  NOT_REQUESTED
  PENDING
  APPROVED
  REJECTED
}

enum EligibilityStatus {
  ELIGIBLE
  NOT_ELIGIBLE
}

enum AssignmentType {
  THEORY
  LAB
}

enum Designation {
  ASSOCIATE_PROFESSOR
  ASSISTANT_PROFESSOR
  PROFESSOR
  VISITING_PROFESSOR
}

enum StaffType {
  TEMPORARY
  REGULAR
  POP
  ADJUNCT
}

enum FacultyGender {
  MALE
  FEMALE
  OTHER
}

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
  OTHER
}

enum QualificationProgramType {
  FULL_TIME
  PART_TIME
}

enum PublicationCategory {
  JOURNAL
  CONFERENCE
  BOOK_CHAPTER_OR_BOOK
  CASE_STUDY
  PATENT
}

enum AdmissionStatus {
  PENDING    // Admin created the shell, student hasn't submitted yet
  SUBMITTED  // Student filled the form and uploaded docs
  APPROVED   // Admin verified the documents
  REJECTED   // Admin rejected the application
}

enum Category {
  GENERAL
  OBC
  SC
  ST
}

enum Quota {
  MERIT
  MANAGEMENT
  SPORTS
  NRI
  SNQ
}

enum DepartmentType {
  DEGREE_GRANTING
  BASIC_SCIENCES
  SERVICE
}

enum Cycle {
  PHYSICS
  CHEMISTRY
  NONE
}

enum CourseApprovalStatus {
  DRAFT
  PENDING
  APPROVED
  NEEDS_REVISION
}

model Department {
  id           String         @id @default(uuid())
  userId       String
  user         User           @relation(fields: [userId], references: [id])
  name         String         @unique
  code         String         @unique
  abbreviation String
  type         DepartmentType @default(DEGREE_GRANTING)
  hods         Hod[]
  sections     Section[]
  students     Student[]
  faculties    Faculty[]
  Course       Course[]
  Admissions   Admission[]

  @@index([name])
}

model Hod {
  id             String      @id @default(uuid())
  user           User        @relation(fields: [userId], references: [id])
  userId         String      @unique
  departmentName String?
  department     Department? @relation(fields: [departmentName], references: [name])
  facultyId      String?     @unique
  faculty        Faculty?    @relation(fields: [facultyId], references: [id])
}

model Section {
  id              String             @id @default(uuid())
  name            String
  department      Department         @relation(fields: [departmentName], references: [name])
  departmentName  String
  semesterId      String
  semester        Semester           @relation(fields: [semesterId], references: [id])
  courses         CourseAssignment[]
  studentSections StudentSection[]
  batches         Batch[]
  cycle           Cycle              @default(NONE)

  @@unique([name, departmentName, semesterId])
  @@index([departmentName, semesterId])
}

/**
 * TODO Change the Name of this model to support L-T-P
 */
model Batch {
  id               String             @id @default(uuid())
  name             String
  section          Section            @relation(fields: [sectionId], references: [id])
  sectionId        String
  students         Student[]          @relation("BatchStudents")
  CourseAssignment CourseAssignment[]

  @@unique([name, sectionId])
}

model StudentSection {
  id           String  @id @default(uuid())
  student      Student @relation(fields: [studentId], references: [id])
  studentId    String
  section      Section @relation(fields: [sectionId], references: [id])
  sectionId    String
  semester     Int
  academicYear String

  @@unique([studentId, sectionId, semester, academicYear])
  @@index([studentId])
  @@index([sectionId])
}

model Student {
  id                String               @id @default(uuid())
  user              User                 @relation(fields: [userId], references: [id])
  userId            String               @unique
  usn               String               @unique
  department        Department           @relation(fields: [departmentName], references: [name])
  departmentName    String
  currentSemester   Int
  semesterId        String?
  semesterNumber    Int?
  programType       ProgramType?
  academicTermId    String?
  academicTermType  SemesterType?
  academicTermYear  String?
  academicTermLabel String?
  studentSections   StudentSection[]
  academicYear      String
  registrations     CourseRegistration[]
  marks             Mark[]
  attendances       Attendance[]
  batches           Batch[]              @relation("BatchStudents")
  admission         Admission?

  @@index([departmentName])
  @@index([semesterId])
  @@index([semesterNumber])
  @@index([programType])
  @@index([academicTermId])
}

model Faculty {
  id                     String                 @id @default(uuid())
  user                   User                   @relation(fields: [userId], references: [id])
  userId                 String                 @unique
  department             Department             @relation(fields: [departmentId], references: [id])
  departmentId           String // Replaced departmentName
  shortName              String // Added shortName
  designation            Designation // Added designation
  employeeId             String?                @unique
  staffType              StaffType?
  qualification          String?
  dateOfJoining          DateTime?
  researchArea           String?
  officeRoom             String?
  gender                 FacultyGender?
  dob                    DateTime?
  bloodGroup             String?
  nationality            String?
  phoneNumber            String?
  personalEmail          String?
  maritalStatus          MaritalStatus?
  aboutYourself          String?
  researchInterests      String?
  otherInformation       String?
  contactInformation     String?
  mobileNumber           String?
  alternateContactNumber String?
  presentAddressLine     String?
  presentCity            String?
  presentState           String?
  presentPincode         String?
  permanentAddressLine   String?
  permanentCity          String?
  permanentState         String?
  permanentPincode       String?
  sameAsPresentAddress   Boolean                @default(false)
  profileUpdatedAt       DateTime?
  teaches                CourseAssignment[]
  qualifications         FacultyQualification[]
  publications           FacultyPublication[]
  experiences            FacultyExperience[]
  hod                    Hod?

  @@index([departmentId])
}

model FacultyQualification {
  id             String                   @id @default(uuid())
  faculty        Faculty                  @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  facultyId      String
  program        String
  degree         String
  specialization String
  institution    String
  programType    QualificationProgramType
  yearPassed     Int
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  @@index([facultyId])
}

model FacultyPublication {
  id                 String              @id @default(uuid())
  faculty            Faculty             @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  facultyId          String
  category           PublicationCategory
  publishedDate      DateTime
  authors            String
  publicationDetails String
  weblink            String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([facultyId])
}

model FacultyExperience {
  id              String    @id @default(uuid())
  faculty         Faculty   @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  facultyId       String
  designation     String
  institutionName String
  startDate       DateTime
  endDate         DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([facultyId])
}

model Admin {
  id     String @id @default(uuid())
  user   User   @relation(fields: [userId], references: [id])
  userId String @unique
}

model Course {
  id             String               @id @default(uuid())
  code           String               @unique
  name           String
  courseMode     CourseMode
  courseType     CourseType
  cycle          Cycle                @default(NONE)
  department     Department           @relation(fields: [departmentName], references: [name])
  departmentName String
  semesterId     String
  semester       Semester             @relation(fields: [semesterId], references: [id])
  semesterNumber Int

  approvalStatus   CourseApprovalStatus @default(DRAFT)
  hasAdminApproved Boolean              @default(false)
  hasCoeApproved   Boolean              @default(false)
  adminNotes       String?
  coeNotes         String?

  // Credit fields (L-T-P-S)
  lectureCredits          Int     @default(0)
  tutorialCredits         Int     @default(0)
  practicalCredits        Int     @default(0)
  skillCredits            Int     @default(0)
  totalCredits            Int

  // Derived field
  hasLaboratoryComponent  Boolean @default(false)

  // SEE Assessment
  seeMaxMarks             Int     @default(0)
  seeMinMarks             Int     @default(0)
  seeWeightage            Int     @default(0)

  // CIE Assessment
  maxNoOfCies             Int     @default(0)
  minNoOfCies             Int     @default(0)
  cieMaxMarks             Int     @default(0)
  cieMinMarks             Int     @default(0)
  cieWeightage            Int     @default(0)

  // Other Assessment
  noOfAssignments         Int     @default(0)
  assignmentMaxMarks      Int     @default(0)
  labMaxMarks             Int     @default(0)
  labMinMarks             Int     @default(0)
  labWeightage            Int     @default(0)
  cumulativeMaxMarks      Int     @default(0)
  cumulativeMinMarks      Int     @default(0)

  // Relations
  assignments    CourseAssignment[]
  registrations  CourseRegistration[]
  marks          Mark[]
  attendances    Attendance[]

  @@index([code])
}

model CourseAssignment {
  id             String         @id @default(uuid())
  course         Course         @relation(fields: [courseId], references: [id])
  courseId       String
  faculty        Faculty        @relation(fields: [facultyId], references: [id])
  facultyId      String
  section        Section        @relation(fields: [sectionId], references: [id])
  sectionId      String
  batch          Batch?         @relation(fields: [batchId], references: [id])
  batchId        String?
  assignmentType AssignmentType
  semester       Int
  academicYear   String
  freezes        Freeze[]

  @@unique([courseId, facultyId, sectionId, batchId, assignmentType, semester, academicYear])
  @@index([sectionId, semester])
  @@index([batchId])
}

model CourseRegistration {
  id           String  @id @default(uuid())
  student      Student @relation(fields: [studentId], references: [id])
  studentId    String
  course       Course  @relation(fields: [courseId], references: [id])
  courseId     String
  semester     Int
  academicYear String
  hasDropped   Boolean @default(false)

  @@unique([studentId, courseId, semester, academicYear])
  @@index([studentId])
  @@index([courseId])
}

model Attendance {
  id                String            @id @default(uuid())
  student           Student           @relation(fields: [studentId], references: [id])
  studentId         String
  course            Course            @relation(fields: [courseId], references: [id])
  courseId          String
  total             Int
  present           Int
  absent            Int
  condonationStatus CondonationStatus @default(NOT_REQUESTED)
  percentage        Float

  @@unique([studentId, courseId])
  @@index([courseId])
}

model Mark {
  id        String            @id @default(uuid())
  student   Student           @relation(fields: [studentId], references: [id])
  studentId String
  course    Course            @relation(fields: [courseId], references: [id])
  courseId  String
  cie1      Float?
  cie2      Float?
  cie3      Float?
  aat1      Float?
  aat2      Float?
  lab1      Float?
  lab2      Float?
  labTotal  Float?
  cieTotal  Float?
  status    EligibilityStatus

  @@unique([studentId, courseId])
  @@index([courseId])
}

model Coe {
  id       String @id @default(uuid())
  user     User   @relation(fields: [userId], references: [id])
  userId   String @unique
}

model Freeze {
  id                 String           @id @default(uuid())
  courseAssignment   CourseAssignment @relation(fields: [courseAssignmentId], references: [id])
  courseAssignmentId String           @unique
  cie1Frozen         Boolean          @default(false)
  cie2Frozen         Boolean          @default(false)
  cie3Frozen         Boolean          @default(false)
  cie1Deadline       DateTime?
  cie2Deadline       DateTime?
  cie3Deadline       DateTime?
  facultyFrozen      Boolean          @default(false)
  hodFrozen          Boolean          @default(false)
  adminFrozen        Boolean          @default(false)
  facultyFrozenAt    DateTime?
  hodFrozenAt        DateTime?
  adminFrozenAt      DateTime?
  frozenByFaculty    User?            @relation("FrozenByFaculty", fields: [frozenByFacultyId], references: [id])
  frozenByFacultyId  String?
  frozenByHod        User?            @relation("FrozenByHod", fields: [frozenByHodId], references: [id])
  frozenByHodId      String?
  frozenByAdmin      User?            @relation("FrozenByAdmin", fields: [frozenByAdminId], references: [id])
  frozenByAdminId    String?
  finalFrozen        Boolean          @default(false)
  finalDeadline      DateTime?
  frozenAt           DateTime?
  User               User?            @relation(fields: [userId], references: [id])
  userId             String?
}

model Admission {
  id              String          @id @default(uuid())
  applicationId   String          @unique
  modeOfAdmission String
  status          AdmissionStatus @default(PENDING)

  semesterId      String
  semester        Semester        @relation(fields: [semesterId], references: [id])

  departmentId                 String
  department                   Department @relation(fields: [departmentId], references: [id])

  firstName                    String?
  middleName                   String?
  lastName                     String?
  categoryClaimed              Category
  categoryAllotted             Category
  quota                        Quota
  entranceExamRank             String?
  originalAdmissionOrderNumber String?
  originalAdmissionOrderDate   DateTime?
  feePayable                   Float?
  feePaid                      Float?
  hostel                       Boolean?
  hostelRoomNumber             String?

  // These are hidden from the applicant form, generated/assigned later
  tempUsn                      String?   @unique
  studentId                    String?   @unique
  student                      Student?  @relation(fields: [studentId], references: [id])
  uniqueId                     String?   @unique

  nameAsPer10th          String?
  dob                    DateTime?
  bloodGroup             String?
  gender                 String?
  primaryPhoneNumber     String?
  secondaryPhoneNumber   String?
  emergencyContactNumber String?
  primaryEmail           String?   @unique
  secondaryEmail         String?

  // Current Address
  currentAddress         String?
  currentCity            String?
  currentArea            String?
  currentDistrict        String?
  currentState           String?
  currentCountry         String?
  currentPincode         String?

  // Permanent Address
  permanentAddress       String?
  permanentCity          String?
  permanentArea          String?
  permanentDistrict      String?
  permanentState         String?
  permanentCountry       String?
  permanentPincode       String?

  placeOfBirth           String?
  stateOfBirth           String?
  religion               String?
  caste                  String?
  subCaste               String?
  motherTongue           String?
  nri                    Boolean?
  nationality            String?
  disability             Boolean?
  disabilityType         String?
  economicallyBackward   Boolean?
  aadharNumber           String?   @unique

  // 10th Grade
  class10thSchoolName       String?
  class10thSchoolType       String?
  class10thSchoolCity       String?
  class10thSchoolState      String?
  class10thSchoolCode       String?
  class10thYearOfPassing    String?
  class10thAggregateScore   Float?
  class10thAggregateTotal   Float?
  class10thMediumOfTeaching String?

  // 12th Grade
  class12thInstituteName    String?
  class12thInstituteType    String?
  class12thInstituteCity    String?
  class12thInstituteState   String?
  class12thInstituteCode    String?
  class12thYearOfPassing    String?
  class12thBranch           String?
  class12thAggregateScore   Float?
  class12thAggregateTotal   Float?
  class12thMediumOfTeaching String?

  fatherName               String?
  fatherEmail              String?
  fatherNumber             String?
  fatherPermanentAddress   String?
  fatherOccupation         String?

  motherName               String?
  motherEmail              String?
  motherNumber             String?
  motherPermanentAddress   String?
  motherOccupation         String?

  guardianName             String?
  guardianEmail            String?
  guardianNumber           String?
  guardianPermanentAddress String?
  guardianOccupation       String?

  photo                           String?
  casteCertificate                String?
  disabilityCertificate           String?
  economicallyBackwardCertificate String?
  aadharCard                      String?
  class10thMarksPdf               String?
  class12thMarksPdf               String?
  transferCertificate             String?
  studyCertificate                String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([semesterId])
}
